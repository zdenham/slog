{
  "name": "slog",
  "module": "src/cli.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build --compile src/cli.ts --outfile slog",
    "build:npm": "bash scripts/build-npm.sh",
    "test": "bun test",
    "test:bin": "bun run build && SLOG_BIN=./slog bun test",
    "deploy": "bash scripts/deploy.sh",
    "test:e2e": "bash scripts/test-e2e.sh"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "ulid": "^3.0.2"
  }
}
